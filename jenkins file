pipeline {
 agent any

 stages {

  stage('Checkout Code') {
   steps {
    deleteDir()
    git branch: 'main', url: 'git@github.com:renjithpj3-ux/new-repo.git'
   }
  }

  stage('Install Dependencies') {
   steps {
    sh 'npm install'
   }
  }

  stage('Run Application') {
   steps {
    sh '''
    pkill node || true
    cd /home/ubuntu/new-repo
    nohup npm start > app.log 2>&1 &
    '''
   }
  }

 }
}
