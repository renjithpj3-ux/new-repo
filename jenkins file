pipeline {
 agent any

 stages {

  stage('Checkout Code') {
   steps {
    git branch: 'main', url: 'git@github.com:renjithpj3-ux/new-repo.git'
   }
  }

  stage('Install Dependencies') {
   steps {
    sh 'npm install'
   }
  }

  stage('Deploy') {
   steps {
    sh 'cp -r . /home/ubuntu/new-repo'
   }
  }

  stage('Run Application') {
   steps {
    sh '''
    pkill node || true
    cd /home/ubuntu/new-repo
    npm start &
    '''
   }
  }

 }
}
